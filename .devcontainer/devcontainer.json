{
  "name": "Maester",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24-trixie",
  "features": {
    "ghcr.io/devcontainers/features/powershell:2": {
      "modules": "Pester, PSFramework, PSModuleDevelopment, PSScriptAnalyzer, Microsoft.Graph.Authentication, Az.Accounts, ExchangeOnlineManagement, MicrosoftTeams"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "extensions": "github/gh-copilot"
    }
  },
  "forwardPorts": [3000, 5173],
  "portsAttributes": {
    "3000": { "label": "Docusaurus Website", "onAutoForward": "notify" },
    "5173": { "label": "Vite Report Dev", "onAutoForward": "notify" }
  },
  "postCreateCommand": "/bin/bash ./.devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "markdown.extension.preview.autoOpenPreview": true,
        "terminal.integrated.defaultProfile.linux": "pwsh",
        "eslint.run": "onSave",
        "cSpell.ignorePaths": [
          "node_modules",
          ".git",
          "dist",
          "build",
          "*.lock"
        ]
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "github.vscode-github-actions",
        "GlenBuktenica.unicode-substitutions",
        "ms-vscode.powershell",
        "streetsidesoftware.code-spell-checker"
      ]
    },
    "codespaces": {
      "openFiles": ["website/docs/contributing.md"]
    }
  },
  "runArgs": ["--network=host"]
}
