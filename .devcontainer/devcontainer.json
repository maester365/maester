// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README for image at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
  "name": "Maester",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-18-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/powershell:1": {
      "modules": "Pester, PSFramework, PSModuleDevelopment, PSScriptAnalyzer, Microsoft.Graph.Authentication, Az.Accounts, ExchangeOnlineManagement, MicrosoftTeams"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [3000, 5173, 1234],
  "postCreateCommand": "/bin/bash ./.devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "pwsh"
      },
      "extensions": [
        "ms-vscode.powershell",
        "ms-vscode.vscode-typescript-next",
        "github.vscode-github-actions",
        "dbaeumer.vscode-eslint",
        "streetsidesoftware.code-spell-checker",
        "ms-vscode.makefile-tools"
      ]
    },
    "codespaces": {
      "openFiles": ["website/docs/contributing.md"]
    }
  },
  "runArgs": ["--network=host"]
}
