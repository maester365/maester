{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Website",
            "type": "shell",
            // Logic: If node_modules doesn't exist, run npm ci first
            "command": "cd website && [ ! -d 'node_modules' ] && npm ci; npm start",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": "Compiled successfully|DONE"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start Report Dev",
            "type": "shell",
            "command": "cd report && [ ! -d 'node_modules' ] && npm ci; npm run dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*",
                    "endsPattern": "ready in|Local:"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Validate Dependencies",
            "type": "shell",
            "command": "pwsh -NoProfile -File ./.devcontainer/Validate-DevContainer.ps1",
            "problemMatcher": []
        }
    ]
}
